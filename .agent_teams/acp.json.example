{
  "providers": {
    "default": {
      "transport": "stdio",
      "protocol": "auto",
      "command": "opencode",
      "args": [
        "acp"
      ],
      "env": {},
      "cwd": "D:/workspace"
    }
  },
  "routing": {
    "coordinator_agent": "local_wrapper",
    "*": "default"
  },
  "timeouts": {
    "session_init_ms": 10000,
    "turn_ms": 120000
  }
}

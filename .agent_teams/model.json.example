{
  "default": {
    "model": "gpt-4o-mini",
    "base_url": "https://api.openai.com/v1",
    "api_key": "${OPENAI_API_KEY}",
    "temperature": 0.2,
    "top_p": 1.0,
    "max_tokens": 1024
  },
  "fast": {
    "model": "gpt-4o-mini",
    "base_url": "https://api.openai.com/v1",
    "api_key": "${OPENAI_API_KEY}",
    "temperature": 0.1,
    "max_tokens": 512
  },
  "claude": {
    "model": "claude-3-5-sonnet-20241022",
    "base_url": "https://api.anthropic.com/v1",
    "api_key": "${ANTHROPIC_API_KEY}",
    "temperature": 0.3,
    "max_tokens": 2048
  }
}
